{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "A business registered in the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "currency": { "type": "string" },
        "vatEnabled": { "type": "boolean" },
        "vatPercentage": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "type", "ownerEmail", "status", "createdAt"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A branch belonging to a business.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactNumber": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "name", "active", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "A user associated with a business or branch.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "role": { "type": "string", "enum": ["Owner", "BranchManager", "Salesperson", "Cashier", "StockController"] },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "role", "displayName", "createdAt"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "An item in the inventory.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "cost": { "type": "number" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "reorder": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["businessId", "name", "price", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A transaction record.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "pending", "refunded"] },
        "createdAt": { "type": "number" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "total", "items", "status", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "logger": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "amount", "description", "createdAt"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Root business documents."
    },
    "/businesses/{businessId}/branches/{branchId}": {
      "schema": "Branch",
      "description": "Branches under a business."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents for both owners and employees."
    },
    "/businesses/{businessId}/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items for a business."
    },
    "/businesses/{businessId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records for a business."
    },
    "/businesses/{businessId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense records for a business."
    }
  }
}
