{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile including roles and business association.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "business_owner", "manager", "salesperson"] },
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["email", "name", "role", "status", "createdAt", "createdBy"]
    },
    "Business": {
      "title": "Business",
      "description": "Merchant business details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "businessType": { "type": "string" },
        "logo": { "type": "string" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "ownerId", "ownerEmail", "status", "createdAt", "createdBy"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Specific business location or branch.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "unit": { "type": "string" },
        "image": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense records.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles."
    },
    "businesses": {
      "schema": "Business",
      "description": "Registered businesses."
    },
    "branches": {
      "schema": "Branch",
      "description": "Business branches."
    },
    "products": {
      "schema": "Product",
      "description": "Inventory products."
    },
    "sales": {
      "schema": "Sale",
      "description": "Sales transactions."
    },
    "expenses": {
      "schema": "Expense",
      "description": "Business expenses."
    },
    "notifications": {
      "schema": "Notification",
      "description": "App notifications."
    }
  }
}
