{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users including super admins, business owners, managers, and salespeople.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "business_owner", "manager", "salesperson"] },
        "businessId": { "type": "string", "description": "ID of the business the user belongs to. Null for super_admin." },
        "branchId": { "type": "string", "description": "ID of the specific branch the user works at. Null for super_admin and business_owner." },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "description": "UID of the user who created this account." }
      },
      "required": ["email", "name", "role", "status", "createdAt"]
    },
    "Business": {
      "title": "Business",
      "description": "A multi-tenant business entity.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "businessType": { "type": "string" },
        "logo": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "ownerId", "ownerEmail", "status", "createdAt"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A physical location or branch of a business.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "managerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "name", "status" , "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items belonging to a specific branch.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "buyingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "lowStockAlert": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "name", "sellingPrice", "quantity", "status", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A recorded transaction.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "salespersonId": { "type": "string" },
        "salespersonName": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "mpesa", "card", "credit"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "voided"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "salespersonId", "items", "total", "paymentMethod", "status", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Recorded business costs.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "category": { "type": "string", "enum": ["rent", "utilities", "salaries", "supplies", "other"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "receiptUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "category", "amount", "date", "status", "createdAt"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Audit log for inventory changes.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["restock", "sale", "adjustment", "loss"] },
        "quantityBefore": { "type": "number" },
        "quantityChanged": { "type": "number" },
        "quantityAfter": { "type": "number" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "productId", "type", "quantityBefore", "quantityChanged", "quantityAfter", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "businesses/{businessId}": {
      "schema": "Business",
      "description": "Multi-tenant business accounts."
    },
    "branches/{branchId}": {
      "schema": "Branch",
      "description": "Business locations."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Inventory items."
    },
    "sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales transactions."
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Branch expenses."
    },
    "stock_movements/{movementId}": {
      "schema": "StockMovement",
      "description": "Stock audit trail."
    }
  }
}
