{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account in the POS system",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "business_owner", "manager", "salesperson"] },
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["email", "name", "role", "status", "createdAt", "createdBy"]
    },
    "Business": {
      "title": "Business",
      "description": "East African Business details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "businessType": { "type": "string" },
        "logo": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "ownerId", "ownerEmail", "phone", "address", "businessType", "status", "createdAt", "createdBy"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Branch owned by a business",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "managerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "name", "location", "phone", "managerId", "status", "createdAt", "createdBy"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product item",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "buyingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "lowStockAlert": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "name", "sku", "category", "buyingPrice", "sellingPrice", "quantity", "unit", "lowStockAlert", "status", "createdAt", "createdBy"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Completed transaction sales receipt",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "salespersonId": { "type": "string" },
        "salespersonName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "mpesa", "card", "credit"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "voided"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "salespersonId", "salespersonName", "items", "subtotal", "discount", "tax", "total", "paymentMethod", "status", "createdAt", "updatedAt", "createdBy"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense details",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "category": { "type": "string", "enum": ["rent", "utilities", "salaries", "supplies", "other"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "category", "description", "amount", "date", "status", "createdAt", "createdBy"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Stock inventory movement logs",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "branchId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["restock", "sale", "adjustment", "loss"] },
        "quantityBefore": { "type": "number" },
        "quantityChanged": { "type": "number" },
        "quantityAfter": { "type": "number" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["businessId", "branchId", "productId", "productName", "type", "quantityBefore", "quantityChanged", "quantityAfter", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Manage user role and status details"
    },
    "businesses/{businessId}": {
      "schema": "Business",
      "description": "Company profiles and credentials"
    },
    "branches/{branchId}": {
      "schema": "Branch",
      "description": "Branch location info and assigned managers"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Store items and inventory levels"
    },
    "sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales invoices and totals"
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Operating expenditure logging"
    },
    "stock_movements/{movementId}": {
      "schema": "StockMovement",
      "description": "Stock change auditable history"
    }
  }
}
