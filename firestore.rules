rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Super admin has full access
    function isSuperAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'jacmwaniki@gmail.com';
    }

    // User is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Get user profile
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // User belongs to this business
    function ownsBusiness(businessId) {
      return isAuth() && userProfile().businessId == businessId;
    }

    // User has role
    function hasRole(role) {
      return isAuth() && userProfile().role == role;
    }

    // Feedback: anyone can create
    match /feedback/{id} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // Announcements: super admin only
    match /announcements/{id} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // Businesses: super admin full, owner reads/writes own
    match /businesses/{businessId} {
      allow read, write: if isSuperAdmin();
      allow read: if ownsBusiness(businessId);
      allow update: if ownsBusiness(businessId) && hasRole('Owner');
      allow create: if isAuth() &&
        request.resource.data.ownerUid == request.auth.uid;

      // Branches
      match /branches/{branchId} {
        allow read, write: if isSuperAdmin();
        allow read: if ownsBusiness(businessId);
        allow write: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager'));
      }

      // Inventory
      match /inventory/{itemId} {
        allow read, write: if isSuperAdmin();
        allow read: if ownsBusiness(businessId);
        allow write: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager') || hasRole('StockController'));
      }

      // Sales — salesperson can create only, manager+ can edit/delete
      match /sales/{saleId} {
        allow read, write: if isSuperAdmin();
        allow create: if ownsBusiness(businessId) && isAuth();
        allow read: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager') ||
           (hasRole('Salesperson') && resource.data.createdBy == request.auth.uid) ||
           (hasRole('Cashier') && resource.data.createdBy == request.auth.uid));
        allow update, delete: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager'));
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read, write: if isSuperAdmin();
        allow create: if ownsBusiness(businessId);
        allow read: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager') ||
           resource.data.loggedBy == request.auth.uid);
        allow update, delete: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager'));
      }

      // All other subcollections
      match /{collection}/{docId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if ownsBusiness(businessId) &&
          (hasRole('Owner') || hasRole('BranchManager'));
      }
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isSuperAdmin();
      // Owner/manager can read users in their business
      allow read: if isAuth() &&
        get(/databases/$(database)/documents/users/$(userId)).data.businessId ==
        userProfile().businessId;
      // Users can read and update their own profile (not role or businessId)
      allow read: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('businessId' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());
      // Owner/manager can create users (staff) in their business
      allow create: if isAuth() &&
        (hasRole('Owner') || hasRole('BranchManager')) &&
        request.resource.data.businessId == userProfile().businessId;
      // Only owner can delete users
      allow delete: if isAuth() && hasRole('Owner') &&
        get(/databases/$(database)/documents/users/$(userId)).data.businessId ==
        userProfile().businessId;
    }

    // Notifications
    match /notifications/{id} {
      allow read, write: if isSuperAdmin();
      allow read: if isAuth() &&
        (resource.data.targetUserId == request.auth.uid ||
         resource.data.targetUserId == 'all');
      allow update: if isAuth() &&
        resource.data.targetUserId == request.auth.uid;
    }
  }
}
