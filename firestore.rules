rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function getUserData(uid) { return get(/databases/$(database)/documents/users/$(uid)).data; }
    function isUserActive() { return getUserData(request.auth.uid).status == 'active'; }
    function isBusinessActive(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.status == 'active';
    }
    function isSuperAdmin() { return isSignedIn() && getUserData(request.auth.uid).role == 'super_admin'; }
    function isBusinessOwner(businessId) {
      let u = getUserData(request.auth.uid);
      return isSignedIn() && u.role == 'business_owner' && u.businessId == businessId && u.status == 'active' && isBusinessActive(businessId);
    }
    function isManagerInBranch(branchId) {
      let u = getUserData(request.auth.uid);
      return isSignedIn() && u.role == 'manager' && u.branchId == branchId && u.status == 'active' && isBusinessActive(u.businessId);
    }
    function isSalespersonInBranch(branchId) {
      let u = getUserData(request.auth.uid);
      return isSignedIn() && u.role == 'salesperson' && u.branchId == branchId && u.status == 'active' && isBusinessActive(u.businessId);
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || isBusinessOwner(getUserData(userId).businessId));
      allow create: if isSignedIn() && (isSuperAdmin() || isBusinessOwner(incoming().businessId));
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (isBusinessOwner(existing().businessId) && incoming().businessId == existing().businessId) ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name']))
      );
    }

    match /businesses/{businessId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == businessId);
      allow create: if isSignedIn() && (isSuperAdmin() || incoming().ownerId == request.auth.uid);
      allow update: if isSignedIn() && (isSuperAdmin() || isBusinessOwner(businessId)) && incoming().ownerId == existing().ownerId;
    }

    match /branches/{branchId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == resource.data.businessId);
      allow create, update: if isSignedIn() && (isSuperAdmin() || isBusinessOwner(incoming().businessId));
    }

    match /products/{productId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == resource.data.businessId);
      allow create, update: if isSignedIn() && (isSuperAdmin() || isBusinessOwner(incoming().businessId) || isManagerInBranch(incoming().branchId));
    }

    match /sales/{saleId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == resource.data.businessId);
      allow create: if isSignedIn() && (isManagerInBranch(incoming().branchId) || isSalespersonInBranch(incoming().branchId));
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        isManagerInBranch(existing().branchId) ||
        (isSalespersonInBranch(existing().branchId) && existing().createdBy == request.auth.uid && (request.time.toMillis() - existing().createdAt.toMillis() < 7200000))
      );
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == resource.data.businessId);
      allow create, update: if isSignedIn() && (isSuperAdmin() || isBusinessOwner(incoming().businessId) || isManagerInBranch(incoming().branchId));
    }

    match /stock_movements/{movementId} {
      allow read: if isSignedIn() && (isSuperAdmin() || getUserData(request.auth.uid).businessId == resource.data.businessId);
      allow create: if isSignedIn() && (isManagerInBranch(incoming().branchId) || isSalespersonInBranch(incoming().branchId));
    }
  }
}
